#!/bin/sh

# aureus-setup-anchor
if [ "$AUREUS_INTERNAL_PUSH" = "true" ]; then
  exit 0
fi

HEAD_BEFORE=$(git rev-parse HEAD)

if npx aureus bump; then
  HEAD_AFTER=$(git rev-parse HEAD)

  # Only re-push and cancel original if bump actually created a commit
  if [ "$HEAD_BEFORE" != "$HEAD_AFTER" ]; then
    AUREUS_INTERNAL_PUSH=true git push || exit 1
    git fetch origin
    echo "✓ Push complete (including version bump)"
    exit 0
  fi
fi

exit 0
